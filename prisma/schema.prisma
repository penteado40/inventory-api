generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  operator
  viewer
}

model Store {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String?   @unique
  address   String?
  phone     String?
  active              Boolean  @default(true)
  requireProductCode  Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  users               User[]
  locationTypes       LocationType[]
  locations           Location[]
}

model User {
  id            Int            @id @default(autoincrement())
  name          String
  email         String         @unique
  password      String
  role          Role           @default(operator)
  storeId       Int?
  phone         String?
  active        Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  store         Store?         @relation(fields: [storeId], references: [id])
  refreshTokens RefreshToken[]
}

model LocationType {
  id        Int        @id @default(autoincrement())
  name      String
  storeId   Int
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  store     Store      @relation(fields: [storeId], references: [id])
  locations Location[]

  @@unique([name, storeId])
}

model Location {
  id             Int          @id @default(autoincrement())
  number         Int
  locationTypeId Int
  storeId        Int
  parentId       Int?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  locationType   LocationType @relation(fields: [locationTypeId], references: [id])
  store          Store        @relation(fields: [storeId], references: [id])
  parent         Location?    @relation("LocationChildren", fields: [parentId], references: [id])
  children       Location[]   @relation("LocationChildren")

  @@unique([locationTypeId, number, parentId, storeId])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
